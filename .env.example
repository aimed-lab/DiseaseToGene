# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
AI_RATE_LIMIT_MAX_REQUESTS=20

# NCBI API Key (PubMed)
NCBI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Invite-only registration — users must enter this shared code to sign up.
# Leave blank to disable self-registration entirely.
SIGNUP_INVITE_CODE=
SUPABASE_API_CACHE_TABLE=external_api_cache
API_CACHE_TTL_SECONDS=86400
DISABLE_API_CACHE=0

# Production origin, e.g. https://your-app.vercel.app
ALLOWED_ORIGIN=
